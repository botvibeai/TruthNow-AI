{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information and usage stats of an authenticated user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Firebase Auth User UID matching request.auth.uid"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "displayName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "photoURL": {
          "type": "string",
          "description": "User profile picture URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of profile creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of last update"
        },
        "totalScansCount": {
          "type": "integer",
          "description": "Total scans executed by this user"
        }
      },
      "required": ["userId", "email", "createdAt", "updatedAt", "totalScansCount"]
    },
    "ApiKey": {
      "title": "Developer API Key",
      "description": "Sandbox/Production keys generated by a developer.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique key ID generated by client"
        },
        "name": {
          "type": "string",
          "description": "Custom name assigned to this key"
        },
        "key": {
          "type": "string",
          "description": "The API key token string itself"
        },
        "createdAt": {
          "type": "string",
          "description": "Date string of key generation"
        },
        "status": {
          "type": "string",
          "enum": ["active", "revoked"],
          "description": "Current authorization status"
        },
        "callsCount": {
          "type": "integer",
          "description": "Total number of simulated API calls made with this key"
        }
      },
      "required": ["id", "name", "key", "createdAt", "status", "callsCount"]
    },
    "Review": {
      "title": "Customer Review",
      "description": "Public testimonial submitted by a verified user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique review ID"
        },
        "author": {
          "type": "string",
          "description": "Name of the review author"
        },
        "role": {
          "type": "string",
          "description": "Officer title/role of the author"
        },
        "company": {
          "type": "string",
          "description": "Company/organization of the author"
        },
        "rating": {
          "type": "integer",
          "description": "Star rating from 1 to 5"
        },
        "avatarSeed": {
          "type": "string",
          "description": "Seed string for avatar generation"
        },
        "text": {
          "type": "string",
          "description": "The review/testimonial content"
        },
        "verifiedQuery": {
          "type": "string",
          "description": "The specific query category/keyword"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the feedback submission"
        },
        "userId": {
          "type": "string",
          "description": "Optional authenticated submitter user ID"
        }
      },
      "required": ["id", "author", "rating", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user document containing preferences and stats."
    },
    "/users/{userId}/apiKeys/{keyId}": {
      "schema": "ApiKey",
      "description": "Subcollection of API credentials owned by the user."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Global public collection of submitted testimonials."
    }
  }
}
